{
  "name": "@signalsandsorcery/texture-plugin",
  "version": "0.2.0",
  "description": "Grid-Bound Texture plugin for Signals & Sorcery — contract-aware non-synth AI textures via Lyria 3.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugin.json": "./src/plugin.json"
  },
  "files": [
    "dist",
    "src/plugin.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@signalsandsorcery/plugin-sdk": "*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@signalsandsorcery/plugin-sdk": "file:../sas-plugin-sdk",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:shiehn/sas-texture-plugin.git"
  },
  "author": "Signals & Sorcery",
  "license": "MIT"
}
